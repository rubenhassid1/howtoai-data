# Required: Secret key for signing magic link tokens (generate with: openssl rand -hex 32)
AUTH_SECRET=your-secret-key-here

# Optional: Resend API key for sending magic link emails
# Get one at https://resend.com (free tier: 100 emails/day)
# If not set, magic links will be logged to the console (dev mode)
RESEND_API_KEY=

# Optional: Override the base URL for magic links (auto-detected on Vercel)
# BASE_URL=https://your-domain.com
